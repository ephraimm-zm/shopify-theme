<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ shop.name }} &ndash; Coming Soon</title>
    {{ content_for_header }}
    {{- 'base.css' | asset_url | stylesheet_tag -}}
    {{- 'theme.css' | asset_url | stylesheet_tag -}}
  </head>

  <body class="template-password">
    <main id="MainContent" class="password-page">
      <div class="password-page__inner">
        <h1 class="password-page__logo">{{ shop.name }}</h1>

        <div class="password-page__message">
          <h2>Opening Soon</h2>
          <p>Enter the password to get early access.</p>
        </div>

        {%- form 'storefront_password', class: 'password-page__form' -%}
          {{ form.errors | default_errors }}
          <div class="password-page__field">
            <label for="Password" class="visually-hidden">Password</label>
            <input
              type="password"
              name="password"
              id="Password"
              class="password-page__input"
              autocomplete="current-password"
              placeholder="Enter your password"
            >
            <button type="submit" class="password-page__submit btn btn--primary">
              Enter
            </button>
          </div>
        {%- endform -%}
      </div>
    </main>
  </body>
</html>
