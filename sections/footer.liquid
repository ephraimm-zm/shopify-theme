<footer class="footer">
  <div class="page-width">
    <div class="footer__grid">

      <!-- Brand column -->
      <div class="footer__brand">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: width: 160
            | image_tag: alt: shop.name, class: 'footer__logo', loading: 'lazy'
          }}
        {%- else -%}
          <span class="footer__logo-text">{{ shop.name }}</span>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <p class="footer__description">{{ section.settings.description }}</p>
        {%- endif -%}

        <!-- Social icons -->
        <ul class="footer__social" role="list">
          {%- if section.settings.instagram_url != blank -%}
            <li>
              <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="footer__social-link">IG</a>
            </li>
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}
            <li>
              <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="footer__social-link">TT</a>
            </li>
          {%- endif -%}
          {%- if section.settings.youtube_url != blank -%}
            <li>
              <a href="{{ section.settings.youtube_url }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="footer__social-link">YT</a>
            </li>
          {%- endif -%}
        </ul>
      </div>

      <!-- Navigation columns from menus -->
      {%- for i in (1..3) -%}
        {%- assign menu_key = 'menu_' | append: i -%}
        {%- assign heading_key = 'menu_' | append: i | append: '_heading' -%}
        {%- assign menu_handle = section.settings[menu_key] -%}
        {%- assign menu_heading = section.settings[heading_key] -%}

        {%- if menu_handle != blank -%}
          {%- assign nav = linklists[menu_handle] -%}
          {%- if nav.links.size > 0 -%}
            <div class="footer__column">
              {%- if menu_heading != blank -%}
                <h3 class="footer__column-heading">{{ menu_heading }}</h3>
              {%- endif -%}
              <ul class="footer__column-list" role="list">
                {%- for link in nav.links -%}
                  <li><a href="{{ link.url }}" class="footer__column-link">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>
      <ul class="footer__policy-list" role="list">
        {%- for policy in shop.policies -%}
          {%- if policy != blank -%}
            <li><a href="{{ policy.url }}" class="footer__policy-link">{{ policy.title }}</a></li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "limit": 1,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand description"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },
    {
      "type": "text",
      "id": "menu_1_heading",
      "label": "Column 1 heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Column 1 menu"
    },
    {
      "type": "text",
      "id": "menu_2_heading",
      "label": "Column 2 heading",
      "default": "Help"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Column 2 menu"
    },
    {
      "type": "text",
      "id": "menu_3_heading",
      "label": "Column 3 heading",
      "default": "About"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Column 3 menu"
    }
  ]
}
{% endschema %}
