<section
  class="hero-banner{% if section.settings.text_position == 'center' %} hero-banner--centered{% endif %}"
  style="min-height: {{ section.settings.min_height }}px;"
>
  {%- if section.settings.video != blank -%}
    <div class="hero-banner__media hero-banner__media--video">
      {{
        section.settings.video
        | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, class: 'hero-banner__video'
      }}
    </div>
  {%- elsif section.settings.image != blank -%}
    <div class="hero-banner__media">
      {{
        section.settings.image
        | image_url: width: 1920
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          class: 'hero-banner__image',
          alt: section.settings.image.alt | default: shop.name
      }}
    </div>
  {%- else -%}
    <div class="hero-banner__media hero-banner__media--placeholder">
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    </div>
  {%- endif -%}

  <div class="hero-banner__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>

  <div class="hero-banner__content page-width">
    {%- if section.settings.subheading != blank -%}
      <p class="hero-banner__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="hero-banner__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_url }}" class="btn btn--primary hero-banner__btn">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background video"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height (px)",
      "min": 200,
      "max": 900,
      "step": 50,
      "default": 600
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity (%)",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Centre" }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "New Season"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BE A VISIONARY"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
