<section class="image-with-text{% if section.settings.layout == 'image_second' %} image-with-text--reverse{% endif %}">
  <div class="page-width">
    <div class="image-with-text__grid">

      <div class="image-with-text__media">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 800
            | image_tag: loading: 'lazy', class: 'image-with-text__image', alt: section.settings.image.alt
          }}
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg image-with-text__image' }}
        {%- endif -%}
      </div>

      <div class="image-with-text__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="image-with-text__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="image-with-text__text rte">{{ section.settings.text }}</div>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_url }}" class="btn btn--primary">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with Text",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "image_first", "label": "Image first" },
        { "value": "image_second", "label": "Image second" }
      ],
      "default": "image_first"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BUILT FOR PERFORMANCE"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Every piece engineered to push your limits.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Image with Text"
    }
  ]
}
{% endschema %}
